PORT=8787
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,https://istek-zimmet.vercel.app
API_PUBLIC_URL=http://localhost:8787

# Default instance icin SQL_SERVER=localhost ve SQL_PORT=1433 kullanabilirsiniz.
# SQLEXPRESS gibi named instance icin:
# SQL_SERVER=localhost\SQLEXPRESS
# SQL_PORT=
SQL_SERVER=localhost\SQLEXPRESS
SQL_PORT=
SQL_DATABASE=IstekZimmet
SQL_USER=zimmet_api
SQL_PASSWORD=change-me
SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERTIFICATE=true
GOOGLE_CLIENT_ID=333289043957-05l0hq2r1aqafnclifl9dnvipkr99ba5.apps.googleusercontent.com
APP_SECRET=replace-with-long-random-secret
AD_AGENT_SECRET=replace-with-ad-agent-secret
PERSONNEL_SYNC_SECRET=replace-with-personnel-sync-secret

# OTP SMS gonderimi icin opsiyonel Mobildev ayarlari
MOBILDEV_SMS_API_URL=https://xmlapi.mobildev.com/
MOBILDEV_API_KEY=
MOBILDEV_API_SECRET=
MOBILDEV_ORIGINATOR=

# PDF uretimi ve kuyruk isleyici
PDF_CHROME_PATH=
QUEUE_WORKER_ENABLED=false
QUEUE_WORKER_INTERVAL_MS=30000
QUEUE_MAX_JOBS_PER_RUN=2
GENERATED_PDF_DIR=
GENERATED_EXPORT_DIR=

# Node PDF -> Google Drive/Gmail Apps Script koprusu
GOOGLE_BRIDGE_URL=
GOOGLE_BRIDGE_SECRET=
GOOGLE_BRIDGE_UPLOAD_ACTION=uploadGeneratedPdf
